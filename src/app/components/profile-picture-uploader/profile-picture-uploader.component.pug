.profile-pic-container((click)='triggerFileInput()', *ngIf='!busy; else loading')
  .pic-container
    .profile-pic([ngClass]="{'empty': !profilePictureUrl}", [ngStyle]="{'background-image': profilePictureUrl ? 'url(' + profilePictureUrl + ')' : ''}")

ng-template(#loading)
  ion-skeleton-text.pic-container

input(
  #fileInput,
  *ngIf='editable',
  type='file',
  accept='image/*',
  (change)='onFileSelected($event)',
  style='display: none'
)